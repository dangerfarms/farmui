{
  "name": "@farmui/core",
  "version": "1.0.0",
  "description": "Beautiful React components, fast & accessible — zero-runtime, built on native modern CSS.",
  "license": "MIT",
  "author": "Danger Farms",
  "homepage": "https://farmui.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dangerfarms/farmui.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/dangerfarms/farmui/issues"
  },
  "keywords": [
    "react",
    "components",
    "component-library",
    "ui",
    "design-system",
    "css",
    "zero-runtime",
    "accessible",
    "a11y",
    "modern-css",
    "dark-mode"
  ],
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup && node scripts/build-css.mjs",
    "dev": "tsup --watch",
    "check-types": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "storybook": "storybook dev -p 6006 --no-open",
    "build-storybook": "storybook build"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^10.4.2",
    "@storybook/addon-docs": "^10.4.2",
    "@storybook/react-vite": "^10.4.2",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^25.0.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "storybook": "^10.4.2",
    "tsup": "^8.5.0",
    "typescript": "5.9.2",
    "vite": "^6.0.0",
    "vitest": "^3.0.0",
    "vitest-axe": "^0.1.0"
  }
}
